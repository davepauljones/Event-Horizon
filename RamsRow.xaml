<UserControl x:Class="Event_Horizon.RamsRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Event_Horizon"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="1314" MinWidth="1314" MaxWidth="1314">
    <Grid x:Name="BackgroundGrid" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="44" MaxWidth="44"/>
            <ColumnDefinition Width="Auto" MinWidth="98" MaxWidth="98"/>
            <ColumnDefinition Width="Auto" MinWidth="60" MaxWidth="60"/>
            <ColumnDefinition Width="Auto" MinWidth="306" MaxWidth="306"/>
            <ColumnDefinition Width="Auto" MinWidth="38" MaxWidth="38"/>
            <ColumnDefinition Width="Auto" MinWidth="236" MaxWidth="236"/>
            <ColumnDefinition Width="Auto" MinWidth="38" MaxWidth="38"/>
            <ColumnDefinition Width="Auto" MinWidth="150" MaxWidth="150"/>
            <ColumnDefinition Width="Auto" MinWidth="139" MaxWidth="139"/>
            <ColumnDefinition Width="Auto" MinWidth="18" MaxWidth="18"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#f7f8f9" Height="18" VerticalAlignment="Top" Margin="0,5,5,0">
            <Grid.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="1" Opacity="0.2" />
            </Grid.Effect>
            <TextBlock x:Name="RamsIDTextBlock" Text="00000" Foreground="Black" FontSize="13" Margin="2,0,2,0" Padding="0" TextAlignment="Right" VerticalAlignment="Top"/>
        </Grid>

        <TextBlock Grid.Column="1" x:Name="CreatedDateTimeTextBlock" Text="04/08/23 16:35" Foreground="Black" FontSize="13" MaxWidth="90" MinWidth="90" Margin="0,5,0,0"/>
        <TextBlock Grid.Column="2" x:Name="JobNoTextBlock" Text="024589" Foreground="Black" FontSize="13" Width="54" Height="18" MaxWidth="54" HorizontalAlignment="Left" TextAlignment="Right"/>
        <TextBlock Grid.Column="3" x:Name="DescriptionTextBlock" Text="Mary had a little" Foreground="Black" FontSize="13" Margin="6,0,5,0" Width="320" Height="18" MaxWidth="320" HorizontalAlignment="Left" TextWrapping="NoWrap"/>

        <Border x:Name="RamsProfileTypeFontAwesomeIconBorder" Grid.Column="4" Style="{DynamicResource EventTypeToken_BorderStyle}">
            <fa:FontAwesome x:Name="RamsProfileTypeFontAwesomeIcon" Icon="User" Style="{DynamicResource EventTypeToken_FontAwesomeStyle}"/>
        </Border>

        <TextBlock x:Name="RamsProfileTypeTextBlock" Grid.Column="5" Text="Profile Type" Style="{DynamicResource EventTypeText_TextBlockStyle}"/>

        <Grid x:Name="UserTokenGrid" Grid.Column="6" Style="{DynamicResource EllipseToken_GridStyle}">
            <Ellipse x:Name="UserEllipse" Style="{DynamicResource EllipseToken_EllipseStyle}"/>
            <Label x:Name="UserLabel" Content="TM" Style="{DynamicResource EllipseToken_LabelStyle}"/>
        </Grid>

        <TextBlock x:Name="ClientNameTextBlock" Grid.Column="7" Text="Clients Name" Margin="10,0,5,0" Style="{DynamicResource EventTypeText_TextBlockStyle}"/>
        <TextBlock x:Name="SiteTextBlock" Grid.Column="8" Text="Site" Margin="10,0,5,0" Style="{DynamicResource EventTypeText_TextBlockStyle}"/>
        <TextBlock x:Name="LocationActivityTextBlock" Grid.Column="9" Text="Location Activity" Margin="10,0,5,0" Style="{DynamicResource EventTypeText_TextBlockStyle}"/>
    </Grid>
</UserControl>