<UserControl x:Class="Event_Horizon.EngineerRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Event_Horizon"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="1314" MinWidth="1314" MaxWidth="1314">
    <Grid x:Name="BackgroundGrid" Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="44" MaxWidth="44"/>
            <ColumnDefinition Width="Auto" MinWidth="90" MaxWidth="90"/>
            <ColumnDefinition Width="Auto" MinWidth="264" MaxWidth="264"/>
            <ColumnDefinition Width="Auto" MinWidth="178" MaxWidth="178"/>
            <ColumnDefinition Width="Auto" MinWidth="136" MaxWidth="136"/>

        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#f7f8f9" Height="18" VerticalAlignment="Top" Margin="0,5,5,0">
            <Grid.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="1" Opacity="0.2" />
            </Grid.Effect>
            <TextBlock x:Name="RamsIDTextBlock" Text="00000" Foreground="Black" FontSize="13" Margin="2,0,2,0" Padding="0" TextAlignment="Right" VerticalAlignment="Top"/>
        </Grid>

        <TextBlock Grid.Column="1" x:Name="CreatedDateTimeTextBlock" Text="04/08/23 16:35" Foreground="Black" FontSize="13" MaxWidth="90" MinWidth="90" Margin="0,5,0,0" HorizontalAlignment="Left"/>
        <TextBlock Grid.Column="2" x:Name="NameTextBlock" Text="Joe Bloggs" Foreground="Black" FontSize="13" Width="52" Height="18" MaxWidth="54" HorizontalAlignment="Left" TextAlignment="Right"/>
        <TextBlock Grid.Column="3" x:Name="RoleTextBlock" Text="Agitator" Foreground="Black" FontSize="13" Margin="6,0,5,0" Width="266" Height="18" MaxWidth="266" HorizontalAlignment="Left" TextWrapping="NoWrap"/>
        <TextBlock x:Name="CompetenceDetailsTextBlock" Grid.Column="4" Text="Jack of all trades, master of none" Margin="4,0,5,0" Style="{DynamicResource EventTypeText_TextBlockStyle}"/>

    </Grid>
</UserControl>