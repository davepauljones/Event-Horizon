<UserControl x:Class="Event_Horizon.EngineerRow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Event_Horizon"
             xmlns:fa="clr-namespace:FontAwesome.WPF;assembly=FontAwesome.WPF"
             mc:Ignorable="d"
             d:DesignHeight="32" d:DesignWidth="1314" MinWidth="1314" MaxWidth="1314">
    <Grid x:Name="BackgroundGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="36" MaxWidth="44"/>
            <ColumnDefinition Width="Auto" MinWidth="90" MaxWidth="90"/>
            <ColumnDefinition Width="Auto" MinWidth="36" MaxWidth="44"/>
            <ColumnDefinition Width="Auto" MinWidth="160" MaxWidth="160"/>
            <ColumnDefinition Width="Auto" MinWidth="200" MaxWidth="200"/>
            <ColumnDefinition Width="Auto" MinWidth="500" MaxWidth="500"/>

        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Background="#f7f8f9" Height="18" VerticalAlignment="Top" Margin="0,5,5,0">
            <Grid.Effect>
                <DropShadowEffect Color="Black" Direction="320" ShadowDepth="1" Opacity="0.2" />
            </Grid.Effect>
            <TextBlock x:Name="RamsIDTextBlock" Text="00000" Foreground="Black" FontSize="13" Margin="2,0,0,0" Padding="0" TextAlignment="Right" VerticalAlignment="Top"/>
        </Grid>

        <TextBlock Grid.Column="1" x:Name="CreatedDateTimeTextBlock" Text="04/08/23 16:35" Foreground="Black" FontSize="13" MaxWidth="90" MinWidth="90" Margin="0,5,0,0" HorizontalAlignment="Left"/>

        <Grid Grid.Column="2" Grid.Row="1" Style="{DynamicResource EllipseToken_GridStyle}">
            <Ellipse x:Name="OriginUserEllipse" Style="{DynamicResource EllipseToken_EllipseStyle}"/>
            <Label x:Name="OriginUserLabel" Content="DJ" Style="{DynamicResource EllipseToken_LabelStyle}"/>
        </Grid>

        <TextBlock Grid.Column="3" x:Name="NameTextBlock" Text="Joe Bloggs" Margin="12,0,0,0" Foreground="Black" FontSize="13" Width="158" Height="18" MaxWidth="158"/>
        <TextBlock Grid.Column="4" x:Name="RoleTextBlock" Text="Agitator" Margin="13,0,0,0" FontSize="13" Width="198" Height="18" MaxWidth="198"/>
        <TextBlock x:Name="CompetenceDetailsTextBlock" Grid.Column="5" Text="Jack of all trades, master of none" Margin="14,0,0,0" Width="498" Height="18" MaxWidth="498"/>

    </Grid>
</UserControl>